// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contact {
  id           String    @id @default(cuid())
  displayName  String
  nickname     String?
  notes        String?
  organization String?
  title        String?
  birthday     DateTime?
  isArchived   Boolean   @default(false)
  // communityId заполнится позже алгоритмом кластеризации
  communityId  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  identities    ContactIdentity[]
  phoneNumbers  PhoneNumber[]
  emails        Email[]
  urls          ContactUrl[]
  addresses     ContactAddress[]
  attributes    ContactAttribute[]
  chatMembers   ChatMember[]
  tagsOnContact ContactTag[]
  commonChats   CommonChat[]

  // связи: contact A и contact B; для нормализации храним только пары где aId < bId
  relationshipsA Relationship[] @relation("RelationshipA")
  relationshipsB Relationship[] @relation("RelationshipB")

  @@index([isArchived])
  @@index([displayName])
}

model ContactIdentity {
  id          String   @id @default(cuid())
  contactId   String
  // 'vcard' | 'telegram' | 'telegram_self' | 'telegram_addressbook' | 'telegram_shared'
  // | 'whatsapp' | 'linkedin' | 'facebook' | 'vk' | 'twitter' | 'manual'
  source      String
  sourceId    String // UID из vCard, user_id из Telegram, sha256(phone) для addressbook
  handle      String? // username (@vasya), telegram username, и т.д.
  displayName String? // имя в источнике (может отличаться от Contact.displayName)
  // 'imported' — реальный импорт из источника с богатыми данными;
  // 'self_reported' — записанная пользователем ссылка (vCard X-SOCIALPROFILE);
  // 'observed' — зарезервировано для «День групп» (увиденные участники чужих групп)
  confidence  String   @default("imported")
  // true если эта identity была заменена более достоверной (например
  // telegram_addressbook → telegram). Не удаляется, остаётся как
  // исторический след для будущих ручных проверок.
  superseded  Boolean  @default(false)
  rawData     String? // JSON-строка с оригинальными данными источника (для отладки и будущего разбора)

  // Telegram (и в будущем другие сети) enrichment fields:
  bio              String?
  photoFileId      String? // короткий sha256-хэш имени файла в storage/<source>-photos/<id>.jpg
  businessHours    String? // JSON-строка (Premium business hours)
  businessLocation String? // JSON-строка (Premium business location)
  isVerified       Boolean @default(false)
  isPremium        Boolean @default(false)
  isBot            Boolean @default(false)
  isScam           Boolean @default(false)
  isFake           Boolean @default(false)
  commonChatsCount Int?
  // 'recently' | 'within_week' | 'within_month' | 'long_ago' | 'hidden' | 'online'
  lastSeenStatus   String?

  // Timestamp of the last successful (or attempted) users.GetFullUser call.
  // NULL = never tried — Phase 3 enrichment looks at this for resumability.
  // Set on both success AND failure (deleted/banned/restricted users) so we
  // don't retry the same dead user every time.
  enrichedAt DateTime?

  // If the user has a personal channel attached to the profile (Premium
  // feature), this stores the Chat.sourceId of that channel.
  personalChannelChatId String?

  // How we learned about this identity:
  //   'contacts_api'      — contacts.GetContacts (real Telegram contact)
  //   'direct_chat'       — discovered via getUsers because we have a chat with them
  //   'json_addressbook'  — only in JSON addressbook (no live TG account)
  //   'self'              — me (telegram_self)
  //   'self_reported'     — from vCard X-SOCIALPROFILE (legacy)
  //   'mention'           — reserved for future
  //   'group_member'      — reserved for День групп
  discoverySource String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messagesSent    Message[]
  chatMemberships ChatMember[]

  @@unique([source, sourceId])
  @@index([contactId])
  @@index([handle])
  @@index([confidence])
  @@index([superseded])
  @@index([isBot])
  @@index([isPremium])
  @@index([enrichedAt])
  @@index([discoverySource])
}

model ContactUrl {
  id        String  @id @default(cuid())
  contactId String
  url       String
  label     String?
  kind      String  @default("website") // 'website' | 'other'

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model ContactAddress {
  id         String   @id @default(cuid())
  contactId  String
  street     String?
  city       String?
  region     String?
  postalCode String?
  country    String?
  formatted  String // полная человекочитаемая строка для отображения и дедупа
  kind       String   @default("other") // 'home' | 'work' | 'other'
  label      String? // кастомный лейбл из X-ABLabel
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([city])
  @@index([country])
}

model ContactAttribute {
  id        String   @id @default(cuid())
  contactId String
  key       String // 'phonetic_first_name' | 'maiden_name' | 'gender' | 'role' | 'lang' | 'tz' | 'show_as' | 'related_name' | 'anniversary' | ...
  value     String
  label     String? // например тип отношения для related_name ('mother', 'spouse')
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([key])
}

model PhoneNumber {
  id        String  @id @default(cuid())
  contactId String
  number    String // нормализованный E.164 если возможно, иначе сырой
  label     String? // 'mobile' | 'work' | 'home' | etc.
  isPrimary Boolean @default(false)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([number])
  @@index([contactId])
}

model Email {
  id        String  @id @default(cuid())
  contactId String
  address   String
  label     String?
  isPrimary Boolean @default(false)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([address])
  @@index([contactId])
}

model Chat {
  id             String    @id @default(cuid())
  source         String // 'telegram' | 'whatsapp' | 'linkedin' | 'slack' | ...
  sourceId       String // chat_id из исходной системы
  title          String?
  // 'direct' | 'group' | 'channel' | 'supergroup' | 'self' (saved_messages — чат с самим собой)
  type           String
  isArchived     Boolean   @default(false)
  memberCount    Int? // полное число участников (даже если мы не enumerate'им их)
  // Кэш по сообщениям: считается импортёром, потом используется
  // для recency-фильтров и расчёта силы связи (День 6).
  messageCount   Int       @default(0)
  lastMessageAt  DateTime?

  // Группо-чатовые метаданные (Day 3-A: импортируются для groups/channels через getFullChannel).
  description       String?
  inviteLink        String? // только если ты admin
  isPublic          Boolean @default(false)
  photoFileId       String? // <hash>.jpg в storage/telegram-photos/
  megagroup         Boolean @default(false) // true для megagroup (>200), false для канала
  creationDate      DateTime?
  usernames         String? // JSON-массив у каналов с несколькими public usernames
  slowmodeSeconds   Int?
  migratedFromChatId String? // если supergroup пришла из обычной группы

  // For personal channels (Premium feature) — which Contact this channel
  // belongs to. NULL for normal groups/channels you joined.
  linkedToContactId String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members     ChatMember[]
  messages    Message[]
  commonWith  CommonChat[]

  @@unique([source, sourceId])
  @@index([type])
  @@index([isArchived])
  @@index([lastMessageAt])
  @@index([source])
  @@index([memberCount])
}

model ChatMember {
  id         String @id @default(cuid())
  chatId     String
  identityId String

  chat     Chat            @relation(fields: [chatId], references: [id], onDelete: Cascade)
  identity ContactIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  // удобно ходить от участника к контакту: identity.contact
  // но добавим denormalization для производительности
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([chatId, identityId])
  @@index([identityId])
  @@index([contactId])
}

// CommonChat — общие чаты между контактом и пользователем («Me»).
// Day 3-A: таблица создаётся пустой (зарезервирована для «День групп»),
// потому что для импорта participants групп нужна отдельная архитектурная
// сессия — Contact ≠ ChatParticipant.
//
// Будущая семантика: «У контакта X со мной N общих групп»
// (где common = я в чате И контакт X в чате).
model CommonChat {
  id        String @id @default(cuid())
  contactId String
  chatId    String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([contactId, chatId])
  @@index([contactId])
  @@index([chatId])
}

model Message {
  id               String   @id @default(cuid())
  chatId           String
  senderIdentityId String?
  sentAt           DateTime
  text             String
  sourceMessageId  String // оригинальный id из источника

  chat   Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender ContactIdentity? @relation(fields: [senderIdentityId], references: [id], onDelete: SetNull)

  @@unique([chatId, sourceMessageId])
  @@index([sentAt])
  @@index([senderIdentityId])
}

model Relationship {
  id        String   @id @default(cuid())
  // нормализация: всегда aId < bId по алфавиту cuid, чтобы пара хранилась один раз
  aId       String
  bId       String
  type      String // 'co_member' | 'manual' | 'mentioned' | 'knows' | 'friend' | 'family' | 'colleague' | 'classmate' | 'partner'
  strength  Int      @default(1)
  source    String? // 'auto' | 'manual'
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  a Contact @relation("RelationshipA", fields: [aId], references: [id], onDelete: Cascade)
  b Contact @relation("RelationshipB", fields: [bId], references: [id], onDelete: Cascade)

  @@unique([aId, bId, type])
  @@index([aId])
  @@index([bId])
  @@index([type])
  @@index([strength])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#888888")
  createdAt DateTime @default(now())

  contacts ContactTag[]
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

// ImportJob — для отслеживания идущих импортов (на будущее)
model ImportJob {
  id           String    @id @default(cuid())
  source       String // 'vcard' | 'telegram' | ...
  status       String // 'pending' | 'running' | 'done' | 'failed'
  total        Int       @default(0)
  processed    Int       @default(0)
  // Текущая фаза для многофазных импортов (Telegram: parse → contacts → chats → messages → shared).
  // total/processed относятся к текущей фазе, не ко всему импорту.
  currentPhase String?
  errors       String? // JSON массив ошибок
  summary      String? // JSON-сводка обогащения (см. ImportResult.enrichment)
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
}
